# SakuraFilter 环境变量模板
#   复制为 .env 并替换所有 <placeholder> 为实际值
#   严禁将真实 .env 提交到版本控制

# ===== 数据库 =====
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=<db_name>;Username=<db_user>;Password=<db_password>
DB_NAME=<db_name>
DB_USER=<db_user>
DB_PASSWORD=<db_password>

# ===== 对象存储 (MinIO) =====
#   非敏感字段 (Endpoint/BucketName/PublicEndpoint/UseSSL) 已在 appsettings.Development.json 默认;
#   敏感凭证 (AccessKey/SecretKey) 仍由 .env 注入.
#   首次开发: 直接运行 .\start-dev.ps1, 脚本会自动生成 .env 并填入 dev 默认值 (minioadmin/minioadmin).
#   生产环境: 参考 .env.prod.example, 手动替换占位符.
Minio__Endpoint=<minio_endpoint>:9000
Minio__AccessKey=<minio_access_key>
Minio__SecretKey=<minio_secret_key>
Minio__BucketName=sakurafilter
Minio__PublicEndpoint=http://<minio_endpoint>:9000
MINIO_ACCESS_KEY=<minio_access_key>
MINIO_SECRET_KEY=<minio_secret_key>
MINIO_PUBLIC_ENDPOINT=http://<minio_endpoint>:9000
STORAGE_PROVIDER=minio

# ===== 搜索引擎 (Meilisearch) =====
MeiliSearch__Endpoint=http://localhost:7700
MeiliSearch__ApiKey=<meili_api_key_or_empty>

# ===== 后端认证 =====
#   生产环境必须替换为强随机 Token (>=32 字符)
Auth__DevStaticToken=<strong_random_token>
Auth__DevStaticTokenPrevious=
ADMIN_TOKEN=<strong_random_token>

# ===== Cursor HMAC =====
#   用于历史游标签名, 防止客户端篡改 (>=32 字符)
Search__CursorHmacKey=<strong_random_hmac_key>
Search__CursorHmacKeyPrevious=
CURSOR_HMAC_KEY=<strong_random_hmac_key>

# ===== ETL 路径白名单 (P0-3.3 防护) =====
Etl__AllowedImportDirs=["<absolute_path_to_cleaned_dir>"]

# ===== ASP.NET Core 监听地址 =====
ASPNETCORE_URLS=http://localhost:5148

# ===== JWT 认证 =====
# JWT 签名密钥 (>=32 字符, 生产环境必须替换为强随机字符串)
Jwt__SigningKey=<strong_random_jwt_signing_key>
Jwt__Issuer=SakuraFilter
Jwt__Audience=SakuraFilter.Web
Jwt__ExpireMinutes=30
Jwt__RefreshExpireDays=7

# ===== 默认用户初始化 (启动时若 Users 表为空才插入) =====
INITIAL_ADMIN_PASSWORD=<strong_admin_password>
INITIAL_OPERATOR_PASSWORD=<strong_operator_password>
