# SakuraFilter 环境变量模板
#   用法: cp .env.example .env && 编辑 .env 填入生产密钥
#   所有 CHANGE_ME 标记的值必须在生产环境替换为随机密钥
#
# 命名约定:
#   - 后端 (.NET IConfiguration) 用双下划线分隔层级, 例: ConnectionStrings__Postgres
#   - 前端 (Playwright/Vite) 用下划线扁平命名, 例: ADMIN_TOKEN
#   - appsettings.json 中对应字段已置空, 必须通过环境变量或 appsettings.Production.json 覆盖

# ===== 数据库 (PostgreSQL) =====
# 完整连接串 (后端读取此环境变量覆盖 appsettings.json 的空值)
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=spike_test_v3;Username=postgres;Password=CHANGE_ME_TO_STRONG_PASSWORD
# 以下字段供脚本/前端使用 (后端不直接读取)
DB_NAME=spike_test_v3
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# ===== 对象存储 (MinIO) =====
# 后端读取 (覆盖 appsettings.json 的空值)
Minio__Endpoint=localhost:9000
Minio__AccessKey=CHANGE_ME_TO_STRONG_KEY
Minio__SecretKey=CHANGE_ME_TO_STRONG_SECRET
Minio__BucketName=sakurafilter
Minio__PublicEndpoint=http://localhost:9000
# 前端/脚本使用
MINIO_ACCESS_KEY=CHANGE_ME_TO_STRONG_KEY
MINIO_SECRET_KEY=CHANGE_ME_TO_STRONG_SECRET
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
# 存储切换: minio 或 aliyun-oss
STORAGE_PROVIDER=minio

# ===== 搜索引擎 (Meilisearch) =====
MeiliSearch__Endpoint=http://localhost:7700
# 留空则不启用 Master Key (仅开发环境)
MeiliSearch__ApiKey=CHANGE_ME_TO_32_CHAR_KEY

# ===== 后端认证 (Token 轮换) =====
# Admin Token (X-Admin-Token 头), 必须 >= 32 字符, 生产环境必须替换
Auth__DevStaticToken=CHANGE_ME_TO_RANDOM_32_CHAR_STRING
# 轮换过渡期的旧 token (可选, 平滑切换时填写, 轮换完成后置空)
Auth__DevStaticTokenPrevious=
# 前端/脚本使用 (Playwright .spec.ts 读取 process.env.ADMIN_TOKEN)
ADMIN_TOKEN=CHANGE_ME_TO_RANDOM_32_CHAR_STRING

# ===== Cursor HMAC 签名密钥 (分页游标防篡改) =====
# 必须 >= 32 字符, 用于签名搜索游标, 防止前端伪造
Search__CursorHmacKey=CHANGE_ME_TO_RANDOM_32_CHAR_STRING
# 轮换过渡期的旧密钥 (可选)
Search__CursorHmacKeyPrevious=
# 前端/脚本使用
CURSOR_HMAC_KEY=CHANGE_ME_TO_RANDOM_32_CHAR_STRING

# ===== ETL 路径遍历防护 (P0-3.3) =====
# 允许 ETL 导入的 jsonl 文件所在目录白名单 (绝对路径数组)
# 为空时不拦截 (dev 兼容); 生产环境必须配置, 防止路径遍历读取任意文件 (如 /etc/passwd)
# 多个目录用 JSON 数组格式: ["D:\\data\\etl", "D:\\projects\\sakurafilter\\spike-test\\output\\cleaned"]
Etl__AllowedImportDirs=[]

# ===== 阿里云 OSS (可选, STORAGE_PROVIDER=aliyun-oss 时使用) =====
# Aliyun__Endpoint=oss-cn-hangzhou.aliyuncs.com
# Aliyun__AccessKeyId=CHANGE_ME
# Aliyun__AccessKeySecret=CHANGE_ME
# Aliyun__BucketName=sakurafilter-prod
# Aliyun__CdnEndpoint=
