# P1-2: 生产环境变量样例
#   复制: cp .env.prod.example .env.prod
#   必须修改: 所有标 [CHANGE-ME] 的字段
#
#   安全: 此文件 **不入版本控制** (见 .gitignore)
#        部署时通过密钥管理 (Vault / K8s Secret / 1Password CLI) 注入

# ===== 数据库 =====
POSTGRES_DB=sakurafilter
POSTGRES_USER=sakura
POSTGRES_PASSWORD=[CHANGE-ME]32+chars-strong-password

# ===== MeiliSearch =====
MEILI_MASTER_KEY=[CHANGE-ME]32+chars-master-key

# ===== MinIO =====
MINIO_ROOT_USER=[CHANGE-ME]minio-admin
MINIO_ROOT_PASSWORD=[CHANGE-ME]minio-strong-password

# ===== JWT (必须 >= 32 字符) =====
JWT_SIGNING_KEY=[CHANGE-ME]please-generate-with-openssl-rand-base64-48
JWT_ISSUER=sakurafilter-prod
JWT_AUDIENCE=sakurafilter-fe

# ===== 管理员初始 Token (开发模式, 生产应改为 SSO) =====
ADMIN_DEV_TOKEN=[CHANGE-ME]64+chars-rotated-quarterly

# ===== Grafana =====
GRAFANA_USER=admin
GRAFANA_PASSWORD=[CHANGE-ME]change-on-first-login
