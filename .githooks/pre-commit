#!/bin/sh
# SakuraFilter pre-commit hook
# WHY: 防退化 — 任一关键检查失败即拦截 commit
#
# 检查项:
#   1. 前端 critical lint (防 xrefSummary 类缺闭括号 bug)
#   2. 后端编译 (后端代码改动时)
#   3. 按钮契约 (仅在 router/index.ts 或按钮 view 改动时)
#
# 用法:
#   安装: cp .githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
#   或:   git config core.hooksPath .githooks
#
# 跳过: SKIP_HOOKS=1 git commit ...

set -e

# 跳过开关
if [ "$SKIP_HOOKS" = "1" ]; then
  echo "[pre-commit] SKIP_HOOKS=1, skipping all checks"
  exit 0
fi

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

# 收集本次改动的文件
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

# ===== 1. 前端 critical lint =====
#   任何 frontend/src/** 改动都触发
if echo "$STAGED_FILES" | grep -q "^frontend/src/"; then
  echo "[pre-commit] 1/3 前端 critical lint (防缺闭括号 bug)..."
  cd "$REPO_ROOT/frontend"
  if [ -d "node_modules" ]; then
    npm run lint:critical --silent 2>&1 | tail -20
    if [ $? -ne 0 ]; then
      echo ""
      echo "❌ 前端 critical lint 失败"
      echo "   跳过: SKIP_HOOKS=1 git commit ..."
      echo "   或修复后: npm run lint:critical (frontend 目录)"
      exit 1
    fi
  else
    echo "  [SKIP] node_modules 缺失, 请先 npm install"
  fi
  cd "$REPO_ROOT"
fi

# ===== 2. 后端编译 =====
#   任何 backend/src/** 改动都触发
if echo "$STAGED_FILES" | grep -q "^backend/src/"; then
  echo "[pre-commit] 2/3 后端编译检查..."
  if [ -f "$REPO_ROOT/backend/src/SakuraFilter.Api/SakuraFilter.Api.csproj" ]; then
    cd "$REPO_ROOT/backend/src/SakuraFilter.Api"
    dotnet build --nologo --verbosity quiet 2>&1 | tail -10
    if [ ${PIPESTATUS[0]} -ne 0 ]; then
      echo ""
      echo "❌ 后端编译失败"
      exit 1
    fi
  fi
  cd "$REPO_ROOT"
fi

# ===== 3. 按钮契约 (仅在 router/index.ts / 关键 view 改动时) =====
#   WHY: 仅相关文件改动才跑, 避免每次 commit 都全量 E2E
if echo "$STAGED_FILES" | grep -qE "router/index.ts|views/.*View\.vue|utils/http\.ts|composables/useAdminAuth\.ts"; then
  echo "[pre-commit] 3/3 按钮契约检查 (动态路由/鉴权改动)..."
  if [ -f "$REPO_ROOT/spike-test/_test_button_contract.py" ]; then
    # 仅当后端 + 前端都在运行时才执行 (CI 环境可能没有)
    if curl -sf -o /dev/null http://localhost:5148/health/live 2>/dev/null && \
       curl -sf -o /dev/null http://localhost:5173/ 2>/dev/null; then
      cd "$REPO_ROOT/spike-test"
      python _test_button_contract.py 2>&1 | tail -5
      if [ ${PIPESTATUS[0]} -ne 0 ]; then
        echo ""
        echo "❌ 按钮契约检查失败 (动态路由/鉴权改动时强制)"
        echo "   跳过: SKIP_HOOKS=1 git commit ..."
        exit 1
      fi
    else
      echo "  [SKIP] 后端/前端未运行, 跳过 E2E (提交后由 CI 补跑)"
    fi
  fi
  cd "$REPO_ROOT"
fi

echo "[pre-commit] ✅ 全部检查通过"
exit 0
