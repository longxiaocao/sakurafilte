{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": ""
  },
  "Db": {
    "AutoMigrateOnStartup": false
  },
  "MeiliSearch": {
    "Endpoint": "http://localhost:7700",
    "ApiKey": "",
    "IndexName": "products",
    "TimeoutMs": 1000
  },
  "Etl": {
    "RecentErrorBuffer": 5,
    "IndexReplayPollSeconds": 10,
    "IndexReplayBatchSize": 500,
    "AllowedImportDirs": []
  },
  "Minio": {
    "Endpoint": "localhost:9000",
    "AccessKey": "",
    "SecretKey": "",
    "BucketName": "sakurafilter",
    "PublicEndpoint": "http://localhost:9000",
    "UseSSL": false,
    "ImageMaxBytes": 10485760
  },
  "Aliyun": {
    "Endpoint": "oss-cn-hangzhou.aliyuncs.com",
    "AccessKeyId": "",
    "AccessKeySecret": "",
    "BucketName": "sakurafilter-prod",
    "PublicEndpoint": "https://sakurafilter-prod.oss-cn-hangzhou.aliyuncs.com",
    "CdnEndpoint": ""
  },
  "Storage": {
    "Provider": "minio"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:5174",
      "http://localhost:3000"
    ]
  },
  "Search": {
    "CursorHmacKey": "",
    "CursorHmacKeyPrevious": ""
  },
  "Auth": {
    "Enabled": true,
    "DevStaticToken": "",
    "DevStaticTokenPrevious": "",
    "AdminPaths": [
      "/api/admin",
      "/api/etl"
    ],
    "ExemptPaths": [
      "/",
      "/api/search",
      "/api/search/health",
      "/api/products",
      "/scalar",
      "/openapi"
    ]
  },
  "RateLimit": {
    "Enabled": true,
    "GlobalPermitsPerMinute": 600,
    "SearchPermitsPerMinute": 300,
    "EtlPermitsPerMinute": 30
  }
}
