{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Db": {
    "AutoMigrateOnStartup": true
  },
  "Minio": {
    "_comment": "开发环境 MinIO 默认值. AccessKey/SecretKey 为敏感凭证, 仍由 .env 注入 (start-dev.ps1 首次运行自动生成). 非敏感字段在此固化, 避免每个新成员重复配置.",
    "Endpoint": "localhost:9000",
    "BucketName": "sakurafilter",
    "PublicEndpoint": "http://localhost:9000",
    "UseSSL": false,
    "ImageMaxBytes": 10485760
  },
  "Storage": {
    "Provider": "minio"
  }
}
