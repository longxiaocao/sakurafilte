# V2 Task V17-3.4: 生产环境重定向白名单主机
#   部署时替换为实际域名,多个域名用逗号分隔
#   示例: VITE_SAFE_REDIRECT_HOSTS=sakurafilter.com,www.sakurafilter.com
VITE_SAFE_REDIRECT_HOSTS=your-domain.com

# V24-F34 (spec Task 4.5.27): 聚合搜索 API 404 降级开关
#   WHY: prod 默认 false, 404 时直接抛错 "聚合搜索 API 不可用,请联系管理员"
#        避免 fallback 掩盖 nginx 路由配置错误 (仍会 console.error + Sentry 上报)
VITE_ENABLE_LEGACY_FALLBACK=false
